---
import { experiences } from "../Experience/DataExperience";
---

<section id="experience" class="py-32 bg-white">
  <div class="container mx-auto px-6">

    <!-- Header -->
    <div class="mb-16 text-center">
      <span class="text-gray-500 font-bold uppercase tracking-[0.3em] text-xs">
        Professional Career
      </span>
      <h2 class="text-4xl md:text-5xl font-black mt-3 text-gray-900">
        Pengalaman Kerja
      </h2>
      <div class="w-12 h-1.5 bg-gray-300 mt-6 rounded-full mx-auto"></div>
    </div>

    <!-- List -->
    <div class="max-w-4xl mx-auto space-y-8" id="exp-container">
      {experiences.map((exp, index) => (
        <div
          class={`exp-card group p-8 md:p-12 bg-white rounded-[3rem] border border-gray-300 hover:border-black hover:-translate-y-1 transition-all duration-300 opacity-0 translate-x-10 ${
            index >= 3 ? 'hidden extra-exp' : ''
          }`}
        >
          
          <!-- Header -->
          <div class="flex flex-col md:flex-row md:items-center justify-between mb-8 gap-4">
            
            <div>
              <h3 class="text-2xl font-black text-gray-900 group-hover:text-black transition-colors duration-300">
                {exp.role}
              </h3>
              <p class="text-gray-500 text-sm uppercase mt-1">
                {exp.company}
              </p>
            </div>

            <div class="shrink-0">
              <span class="inline-flex items-center h-[36px] px-5 bg-blue-50 text-blue-600 rounded-full text-xs font-bold border border-blue-100 whitespace-nowrap">
                {exp.period}
              </span>
            </div>

          </div>

          <!-- Points -->
          <ul class="space-y-4">
            {exp.points.map((point) => (
              <li class="flex gap-3 text-sm text-gray-700 leading-relaxed">
                <div class="w-1.5 h-1.5 bg-black rounded-full mt-2 shrink-0"></div>
                {point}
              </li>
            ))}
          </ul>

        </div>
      ))}
    </div>

    <!-- Button -->
    <div class="text-center mt-12">
      <button
        id="see-more-btn"
        class="px-8 py-3 rounded-full border border-gray-300 text-sm font-bold hover:bg-black hover:text-white transition-all duration-300"
      >
        See More
      </button>
    </div>

  </div>
</section>

<script>
  const cards = document.querySelectorAll('.exp-card');
const seeMoreBtn = document.getElementById('see-more-btn');
const extraExps = document.querySelectorAll('.extra-exp');

// scroll animation
const observer = new IntersectionObserver((entries) => {
  entries.forEach((entry, index) => {
    if (entry.isIntersecting) {
      setTimeout(() => {
        entry.target.classList.remove('opacity-0', 'translate-x-10');
        entry.target.classList.add('opacity-100', 'translate-x-0');
      }, index * 150);
    }
  });
}, { threshold: 0.2 });

cards.forEach(card => observer.observe(card));

// ✅ FIX DI SINI
if (seeMoreBtn) {
  let expanded = false;

  seeMoreBtn.addEventListener('click', () => {
    expanded = !expanded;

    extraExps.forEach((el, index) => {
      if (expanded) {
        el.classList.remove('hidden');

        setTimeout(() => {
          el.classList.remove('opacity-0', 'translate-x-10');
          el.classList.add('opacity-100', 'translate-x-0');
        }, index * 150);
      } else {
        el.classList.add('opacity-0', 'translate-x-10');

        setTimeout(() => {
          el.classList.add('hidden');
        }, 300);
      }
    });

    seeMoreBtn.textContent = expanded ? 'Show Less' : 'See More';
  });
}
</script>