---
import ProjectsContent from "./ProjectsContent";

---

<section id="projects" class="py-32 relative container mx-auto px-6">

  <!-- HEADER -->
  <div class="mb-16 text-center relative">
    <span class="text-gray-500 font-bold uppercase tracking-[0.3em] text-xs">
      Highlight Work
    </span>
    <h2 class="text-4xl md:text-5xl font-black mt-3 text-gray-900">
      Selected Projects
    </h2>
    <div class="w-12 h-1.5 bg-gray-300 mt-6 rounded-full mx-auto"></div>
    
  </div>

  <!-- CONTENT -->
  <ProjectsContent client:visible />

</section>